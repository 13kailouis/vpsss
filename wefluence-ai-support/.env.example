# Copy file ini ke .env (di VPS, jangan di-commit)
# cp .env.example .env
#
# PENTING:
# - JANGAN pakai quotes ('...') di sekitar value, Docker env_file menganggapnya literal
# - FIREBASE_SERVICE_ACCOUNT harus dalam 1 baris (JSON minified)
# - \n di private_key biarkan sebagai literal \n (jangan newline asli)

GROQ_API_KEY=your_groq_api_key_here

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}
