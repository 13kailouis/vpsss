# =========================================================
# Wefluence Scraper - PRODUCTION SSL config
#
# Pakai file ini setelah:
#   1. Domain ready (A record -> IP VPS)
#   2. SSL certificate udah di-generate via certbot
#
# Cara pakai:
#   1. Edit semua "yourdomain.com" jadi domain kamu
#   2. Copy: cp default.ssl.conf.example conf.d/default.conf
#   3. Reload: docker compose exec nginx nginx -s reload
# =========================================================

limit_req_zone $binary_remote_addr zone=api_limit:10m rate=30r/s;

# Log format: catat IP, origin domain, endpoint, status, user-agent
log_format scraper_log '$time_iso8601 | $remote_addr | origin="$http_origin" | '
                       '"$request" | $status | ua="$http_user_agent"';

upstream caption_scraper_backend {
    server caption-scraper:8000;
    keepalive 32;
}

upstream matrix_scrapper_backend {
    server matrix-scrapper:8000;
    keepalive 32;
}

# Allowed CORS origins — hanya wefluence.app dan localhost
map $http_origin $cors_origin {
    default                     "";
    "http://localhost"          "http://localhost";
    "http://localhost:3000"     "http://localhost:3000";
    "http://localhost:8081"     "http://localhost:8081";
    "https://wefluence.app"     "https://wefluence.app";
    "https://www.wefluence.app" "https://www.wefluence.app";
}

# HTTP -> HTTPS redirect + ACME challenge
server {
    listen 80 default_server;
    server_name caption.yourdomain.com matrix.yourdomain.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# Caption scraper subdomain
server {
    listen 443 ssl http2;
    server_name caption.yourdomain.com;

    ssl_certificate     /etc/letsencrypt/live/caption.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/caption.yourdomain.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options nosniff always;

    access_log /var/log/nginx/scraper_access.log scraper_log;
    error_log  /var/log/nginx/scraper_error.log warn;

    client_max_body_size 1m;
    gzip on;
    gzip_vary on;
    gzip_types application/json text/plain;

    location = / {
        add_header Content-Type text/plain;
        return 200 "Wefluence Caption Scraper - OK\n";
    }

    location / {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin  $cors_origin;
            add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
            add_header Access-Control-Allow-Headers "Content-Type";
            add_header Access-Control-Max-Age       86400;
            add_header Content-Length 0;
            add_header Content-Type "text/plain";
            return 204;
        }

        limit_req zone=api_limit burst=60 nodelay;

        add_header Access-Control-Allow-Origin $cors_origin always;

        proxy_pass http://caption_scraper_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}

# Matrix scraper subdomain
server {
    listen 443 ssl http2;
    server_name matrix.yourdomain.com;

    ssl_certificate     /etc/letsencrypt/live/matrix.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/matrix.yourdomain.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options nosniff always;

    access_log /var/log/nginx/scraper_access.log scraper_log;
    error_log  /var/log/nginx/scraper_error.log warn;

    client_max_body_size 1m;
    gzip on;
    gzip_vary on;
    gzip_types application/json text/plain;

    location = / {
        add_header Content-Type text/plain;
        return 200 "Wefluence Matrix Scraper - OK\n";
    }

    location / {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin  $cors_origin;
            add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
            add_header Access-Control-Allow-Headers "Content-Type";
            add_header Access-Control-Max-Age       86400;
            add_header Content-Length 0;
            add_header Content-Type "text/plain";
            return 204;
        }

        limit_req zone=api_limit burst=60 nodelay;

        add_header Access-Control-Allow-Origin $cors_origin always;

        proxy_pass http://matrix_scrapper_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        proxy_connect_timeout 10s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
    }
}
